    renderState:
      __class: RenderState
      name: !<str> ""
      guid: {a: 13494128781610955897, b: 4099586336673336761}
      rasterization:
        __class: RasterizationState
        name: !<str> ""
        guid: {a: 13781577140874444075, b: 10329851481533192889}

        depthClampEnableName: !<str> ""
        rasterizerDiscardEnable: false
        rasterizerDiscardEnableName: !<str> ""
        polygonMode:
          __class: PolygonMode
          value: FILL
        polygonModeName: !<str> ""
        cullMode:
          __class: CullFace
          value: NONE
        cullModeName: !<str> ""
        frontFace:
          __class: FrontFace
          value: COUNTER_CLOCKWISE
        frontFaceName: !<str> ""
        depthBiasEnable: false
        depthBiasEnableName: !<str> ""
        depthBiasConstantFactor: 0
        depthBiasConstantFactorName: !<str> ""
        depthBiasClamp: 1
        depthBiasClampName: !<str> ""
        depthBiasSlopeFactor: 1
        depthBiasSlopeFactorName: !<str> ""
        lineWidth: 1
        lineWidthName: !<str> ""
      depthstencil:
        __class: DepthStencilState
        name: !<str> ""
        guid: {a: 2756322769977766035, b: 9407320408189192352}
        depthTestEnable: true
        depthTestEnableName: !<str> ""
        depthCompareOp:
          __class: CompareOp
          value: LESS
        depthCompareOpName: !<str> ""
        depthWriteEnable: true
        stencilTestEnable: false
        stencilTestEnableName: !<str> ""
      colorBlend:
        __class: ColorBlendState
        name: !<str> ""
        guid: {a: 17312721030319022729, b: 9259530889526533788}
        blendConstants: {x: 0, y: 0, z: 0, w: 0}
        blendEnableName: !<str> ""
        blendFactorName: !<str> ""
        blendOpName: !<str> ""

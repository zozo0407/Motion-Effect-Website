%YAML 1.1
--- !Prefab &1
name: !<str> "postProcess"
guid: {a: 10829539006215899265, b: 6511969139674959755}
entities:
  - __class: Entity
    name: !<str> CameraWarp
    guid: {a: 17025886785345318689, b: 857574980119305663}
    selfvisible: true
    components:
      - {localId: 2}
      - __class: Camera
        name: !<str> Camera_camera
        guid: {a: 4561777277543298612, b: 8643747681414632085}
        enabled: true
        layerVisibleMask: {__class: DynamicBitset, numBits: 3, values: [4]}
        renderOrder: 1
        type:
          __class: CameraType
          value: ORTHO
        clearColor: {r: 0, g: 0, b: 0, a: 0}
        clearType:
          __class: CameraClearType
          value: COLOR_DEPTH
        alwaysClear: false
        viewport: {x: 0, y: 0, w: 1, h: 1}
        fovy: 60
        fovType:
          __class: CameraFovType
          value: CUSTOM
        orthoScale: 1
        fitMode:
          __class: CameraFitMode
          value: NONE
        zNear: 0.1000000014901161
        zFar: 1000
        renderTexture: {localId: 1, path: rt/RT_1.rt}
        isRootCamera: true
        sortMethod:
          __class: CameraSortMethod
          value: SORT_ORDER_AND_RENDERQUEUES
        rtBackupMode:
          __class: CameraRTBackupMode
          value: NEVER
    layer: 2
  - __class: Entity
    name: !<str> PassWarp
    guid: {a: 12990355596680701559, b: 100562487414679214}
    selfvisible: true
    components:
      - {localId: 3}
      - __class: MeshRenderer
        name: !<str> ""
        guid: {a: 4273038053982235778, b: 14970497344391914626}
        enabled: true
        sharedMaterials:
          - {localId: 1, path: material/Unlit/pp.material}
        sortingOrder: 0
        autoSortingOrder: true
        useFrustumCulling: true
        receiveShadow: true
        lightProbeBlendMode:
          __class: LightProbeBlendMode
          value: OFF
        entirePingPong: false
        mesh: {localId: 1, path: prefabs/Quad.mesh}
        castShadow: false
    layer: 2
standaloneResources:
  __class: Map
--- !Transform &2
name: !<str> Camera_transform
guid: {a: 6070946196242664999, b: 5792176936247886747}
enabled: true
localPosition: {x: 0, y: 0, z: 20}
localScale: {x: 1, y: 1, z: 1}
localOrientation: {w: 1, x: 0, y: 0, z: 0}
children:
  - {localId: 3}
mobility:
  __class: Mobility
  value: Dynamic
--- !Transform &3
name: !<str> ""
guid: {a: 1029081598837245297, b: 5063986838980108469}
enabled: true
localPosition: {x: 0, y: 0, z: -10}
localScale: {x: 1, y: 1, z: 1}
localOrientation: {w: 1, x: 0, y: 0, z: 0}
parent: {localId: 2}
mobility:
  __class: Mobility
  value: Dynamic

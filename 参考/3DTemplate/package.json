{
  "name": "threejs-nodejs-demo",
  "version": "1.0.0",
  "description": "Three.js 3D场景演示 (Node.js版本)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:full": "concurrently \"npm run watch\" \"npm run dev\"",
    "watch": "webpack --watch --mode development",
    "dev:hot": "webpack-dev-server --hot --mode development",
    "build": "webpack --mode production"
  },
  "keywords": [
    "three.js",
    "3d",
    "webgl",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tweenjs/tween.js": "^23.1.3",
    "ccapture.js": "^1.1.0",
    "express": "^4.18.2",
    "raw-loader": "^4.0.2",
    "three": "^0.157.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "lil-gui": "^0.20.0",
    "nodemon": "^3.0.1",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.1"
  }
}

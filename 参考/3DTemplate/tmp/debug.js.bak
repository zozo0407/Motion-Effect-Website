// debug.js - 提供Three.js和全局JS调试功能
const THREE = require('three');

// 调试面板初始化
function createDebugPanel() {
    let panel = document.getElementById('debug-info');
    if (!panel) {
        panel = document.createElement('div');
        panel.id = 'debug-info';
        // 将面板移到右侧，避免与左侧的标题重叠
        panel.style.cssText = 'position:fixed;right:10px;top:80px;width:320px;max-height:60vh;overflow:auto;background:rgba(0,0,0,0.85);color:#fff;z-index:9999;font-size:13px;padding:8px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.5);margin:0;';
        document.body.appendChild(panel);
    }
    
    // 面板标题居中
    let title = document.createElement('div');
    title.style.cssText = 'font-weight:bold;margin-bottom:10px;font-size:14px;border-bottom:1px solid #555;padding-bottom:5px;text-align:center;';
    title.textContent = 'Three.js 调试工具';
    panel.appendChild(title);
    
    // 按钮区
    let btns = document.getElementById('debug-btns');
    if (!btns) {
        btns = document.createElement('div');
        btns.id = 'debug-btns';
        btns.style.cssText = 'margin-bottom:10px;display:flex;flex-wrap:wrap;gap:5px;';
        btns.innerHTML = `
            <button id="reload-btn" style="padding:4px 8px;margin:0;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;flex:1;">重载</button>
            <button id="check-scene-btn" style="padding:4px 8px;margin:0;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;flex:1;">检查场景</button>
            <button id="force-render-btn" style="padding:4px 8px;margin:0;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;flex:1;">强制渲染</button>
            <button id="show-info-btn" style="padding:4px 8px;margin:0;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;flex:1;">详细信息</button>
            <button id="add-test-btn" style="padding:4px 8px;margin:0;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;flex:1;">测试立方体</button>
        `;
        panel.appendChild(btns);
    }
    
    // 信息区域容器
    let infoContainer = document.createElement('div');
    infoContainer.id = 'debug-info-content';
    infoContainer.style.cssText = 'max-height:calc(60vh - 80px);overflow-y:auto;padding-right:5px;';
    panel.appendChild(infoContainer);
    
    // 添加切换显示/隐藏按钮
    let toggleBtn = document.createElement('button');
    toggleBtn.id = 'debug-toggle-btn';
    toggleBtn.textContent = '隐藏调试面板';
    // 将切换按钮放在右上角
    toggleBtn.style.cssText = 'position:fixed;top:10px;right:10px;z-index:10000;padding:4px 8px;background:#333;color:#fff;border:1px solid #555;border-radius:4px;cursor:pointer;';
    toggleBtn.onclick = function() {
        const panel = document.getElementById('debug-info');
        if (panel.style.display === 'none') {
            panel.style.display = 'block';
            this.textContent = '隐藏调试面板';
        } else {
            panel.style.display = 'none';
            this.textContent = '显示调试面板';
        }
    };
    document.body.appendChild(toggleBtn);
}

// 信息输出
function updateDebugInfo(message, isError = false) {
    const contentPanel = document.getElementById('debug-info-content');
    if (!contentPanel) return;
    
    // 如果消息是对象或数组，格式化显示
    let displayMessage = message;
    if (typeof message === 'object' && message !== null) {
        try {
            displayMessage = JSON.stringify(message, null, 2);
        } catch (e) {
            displayMessage = String(message);
        }
    }
    
    // 创建一个新的日志条目
    const logEntry = document.createElement('div');
    logEntry.className = isError ? 'error-log-entry' : 'log-entry';
    logEntry.style.cssText = isError ? 
        'color:#ff5555;margin:5px 0;border-left:3px solid #ff5555;padding:4px 8px;word-wrap:break-word;background:rgba(50,30,30,0.3);' : 
        'color:#fff;margin:5px 0;border-left:3px solid #555;padding:4px 8px;word-wrap:break-word;';
    
    // 处理多行消息，确保正确换行显示
    if (typeof displayMessage === 'string' && displayMessage.includes('\n')) {
        // 对于多行消息，使用pre标签保留格式
        const pre = document.createElement('pre');
        pre.style.cssText = 'margin:0;white-space:pre-wrap;font-family:monospace;font-size:12px;';
        pre.textContent = displayMessage;
        logEntry.appendChild(pre);
    } else {
        logEntry.textContent = displayMessage;
    }
    
    contentPanel.appendChild(logEntry);
    contentPanel.scrollTop = contentPanel.scrollHeight;
    
    // 同时输出到控制台，方便调试
    if (isError) {
        console.error(message);
    } else {
        console.log(message);
    }
}

// 全局JS错误捕获
window.addEventListener('error', function(e) {
    updateDebugInfo('JS错误: ' + e.message, true);
});
window.addEventListener('unhandledrejection', function(e) {
    updateDebugInfo('Promise未捕获: ' + (e.reason && e.reason.message ? e.reason.message : e.reason), true);
});

// 捕获ScriptScene实例，将核心对象暴露到全局
function captureSceneObjects() {
    if (!window._sceneInstance) {
        // 当调试初始化时，尝试寻找已有的ScriptScene实例
        const ScriptScene = require('./core/scriptScene');
        
        // 检查DOM中是否有渲染器的canvas
        const canvases = document.querySelectorAll('canvas');
        if (canvases.length > 0) {
            updateDebugInfo('找到Canvas元素，尝试关联Three.js对象');
        }
        
        // 监听应用初始化，在新对象创建时自动捕获
        const originalInitApp = require('./core/app').initApp;
        if (originalInitApp && typeof originalInitApp === 'function') {
            require('./core/app').initApp = function(container, externalScene) {
                const result = originalInitApp(container, externalScene);
                
                // 延迟一点获取场景实例，等待初始化完成
                setTimeout(() => {
                    // 尝试寻找ScriptScene实例
                    updateDebugInfo('尝试捕获场景对象...');
                    // 获取核心对象引用
                    const scriptSceneInstance = window._sceneInstance;
                    if (scriptSceneInstance) {
                        // 添加到全局window上以便调试
                        window.scene = scriptSceneInstance.scene;
                        window.camera = scriptSceneInstance.camera;
                        window.renderer = scriptSceneInstance.renderer;
                        updateDebugInfo('成功捕获场景对象！');
                    } else {
                        updateDebugInfo('无法找到场景实例', true);
                    }
                }, 200);
                
                return result;
            };
            updateDebugInfo('初始化钩子已设置');
        }
    }
}

// 重写ScriptScene构造函数，捕获实例引用
function patchScriptScene() {
    try {
        const ScriptScene = require('./core/scriptScene');
        const originalConstructor = ScriptScene.prototype.constructor;
        
        // 重写构造函数，保留原始功能但添加全局引用
        ScriptScene.prototype.constructor = function(...args) {
            // 调用原始构造函数
            originalConstructor.apply(this, args);
            
            // 保存实例到全局以便调试访问
            window._sceneInstance = this;
            window.scene = this.scene;
            window.camera = this.camera;
            window.renderer = this.renderer;
            
            updateDebugInfo('ScriptScene实例已捕获');
        };
        
        updateDebugInfo('ScriptScene已补丁修改');
    } catch (e) {
        updateDebugInfo('补丁ScriptScene失败: ' + e.message, true);
    }
}

// Three.js环境检查
function checkThreeEnv() {
    // 先清空之前的内容
    const contentPanel = document.getElementById('debug-info-content');
    if (contentPanel) {
        contentPanel.innerHTML = '';
    }
    
    updateDebugInfo('检查Three.js环境...', false);
    
    // 添加分隔线
    addSeparator('WebGL检查');
    
    try {
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (!gl) {
            updateDebugInfo('WebGL不受支持', true);
        } else {
            updateDebugInfo('WebGL支持正常');
            updateDebugInfo('WebGL版本: ' + gl.getParameter(gl.VERSION));
            const extensions = gl.getSupportedExtensions();
            if (extensions && extensions.length > 0) {
                updateDebugInfo(`支持${extensions.length}个WebGL扩展`);
            }
        }
    } catch (e) {
        updateDebugInfo('WebGL检查错误: ' + e.message, true);
    }
    
    // 尝试从全局变量或_sceneInstance获取场景对象
    if (!window.scene && window._sceneInstance) {
        window.scene = window._sceneInstance.scene;
    }
    if (!window.camera && window._sceneInstance) {
        window.camera = window._sceneInstance.camera;
    }
    if (!window.renderer && window._sceneInstance) {
        window.renderer = window._sceneInstance.renderer;
    }
    
    // 添加分隔线
    addSeparator('场景检查');
    
    if (window.scene) {
        updateDebugInfo('场景对象数量: ' + window.scene.children.length);
        
        // 按类型统计
        const stats = {
            lights: window.scene.children.filter(obj => obj.isLight).length,
            meshes: window.scene.children.filter(obj => obj.isMesh).length,
            cameras: window.scene.children.filter(obj => obj.isCamera).length,
            helpers: window.scene.children.filter(obj => obj.isHelper || obj.type.includes('Helper')).length,
            other: window.scene.children.filter(obj => !obj.isLight && !obj.isMesh && !obj.isCamera && !obj.isHelper && !obj.type.includes('Helper')).length
        };
        
        updateDebugInfo(`场景统计: ${stats.meshes}个模型, ${stats.lights}个光源, ${stats.cameras}个相机, ${stats.helpers}个辅助对象`);
        
        // 添加分隔线
        addSeparator('场景对象列表');
        
        // 创建表格显示对象
        const table = document.createElement('table');
        table.style.cssText = 'width:100%;border-collapse:collapse;font-size:12px;margin-top:5px;color:#fff;';
        
        // 添加表头
        const thead = document.createElement('thead');
        thead.innerHTML = `
            <tr style="text-align:left;border-bottom:1px solid #555;">
                <th style="padding:3px;width:10%;">ID</th>
                <th style="padding:3px;width:25%;">类型</th>
                <th style="padding:3px;width:35%;">名称</th>
                <th style="padding:3px;width:30%;">位置</th>
            </tr>
        `;
        table.appendChild(thead);
        
        // 添加表格内容
        const tbody = document.createElement('tbody');
        window.scene.children.forEach((obj, idx) => {
            const row = document.createElement('tr');
            row.style.cssText = idx % 2 === 0 ? 'background:rgba(50,50,50,0.3);' : '';
            
            // 格式化位置信息
            const position = obj.position ? 
                `${obj.position.x.toFixed(1)},${obj.position.y.toFixed(1)},${obj.position.z.toFixed(1)}` : 
                'N/A';
            
            row.innerHTML = `
                <td style="padding:3px;">${idx}</td>
                <td style="padding:3px;">${obj.type}</td>
                <td style="padding:3px;">${obj.name || '未命名'}</td>
                <td style="padding:3px;">${position}</td>
            `;
            tbody.appendChild(row);
        });
        table.appendChild(tbody);
        
        // 将表格添加到内容区域
        contentPanel.appendChild(table);
    } else {
        updateDebugInfo('场景未初始化', true);
        updateDebugInfo('尝试重新捕获场景对象...');
        captureSceneObjects();
    }
}

// 添加分隔线和小标题
function addSeparator(title) {
    const contentPanel = document.getElementById('debug-info-content');
    if (!contentPanel) return;
    
    const separator = document.createElement('div');
    separator.style.cssText = 'border-bottom:1px solid #555;margin:10px 0 5px 0;padding-bottom:3px;font-weight:bold;color:#aaddff;';
    separator.textContent = title || '';
    contentPanel.appendChild(separator);
}

// 强制渲染
function forceRender() {
    updateDebugInfo('尝试强制渲染...');
    
    // 尝试从_sceneInstance获取对象
    if (!window.scene && window._sceneInstance) {
        window.scene = window._sceneInstance.scene;
    }
    if (!window.camera && window._sceneInstance) {
        window.camera = window._sceneInstance.camera;
    }
    if (!window.renderer && window._sceneInstance) {
        window.renderer = window._sceneInstance.renderer;
    }
    
    if (window.scene && window.camera && window.renderer) {
        const geometry = new THREE.BoxGeometry(3, 3, 3);
        const material = new THREE.MeshBasicMaterial({color: 0xff0000});
        const cube = new THREE.Mesh(geometry, material);
        cube.name = "调试立方体(红色)";
        cube.position.set(0, 3, 0);
        window.scene.add(cube);
        window.renderer.render(window.scene, window.camera);
        updateDebugInfo('已添加红色立方体并强制渲染');
        function animateDebugCube() {
            requestAnimationFrame(animateDebugCube);
            cube.rotation.x += 0.01;
            cube.rotation.y += 0.01;
            window.renderer.render(window.scene, window.camera);
        }
        animateDebugCube();
    } else {
        updateDebugInfo('无法强制渲染：场景/相机/渲染器未初始化', true);
        updateDebugInfo('尝试重新捕获场景对象...');
        captureSceneObjects();
    }
}

// 显示详细信息
function showInfo() {
    updateDebugInfo('收集Three.js环境信息...');
    
    // 尝试从_sceneInstance获取对象
    if (!window.scene && window._sceneInstance) {
        window.scene = window._sceneInstance.scene;
    }
    if (!window.camera && window._sceneInstance) {
        window.camera = window._sceneInstance.camera;
    }
    if (!window.renderer && window._sceneInstance) {
        window.renderer = window._sceneInstance.renderer;
    }
    
    if (window.renderer) {
        updateDebugInfo('渲染器信息:');
        updateDebugInfo('  类型: ' + window.renderer.constructor.name);
        updateDebugInfo('  像素比: ' + window.renderer.getPixelRatio());
        updateDebugInfo('  尺寸: ' + window.renderer.getSize(new THREE.Vector2()).width + 'x' + window.renderer.getSize(new THREE.Vector2()).height);
        updateDebugInfo('  阴影启用: ' + window.renderer.shadowMap.enabled);
    } else {
        updateDebugInfo('渲染器未初始化', true);
    }
    if (window.camera) {
        updateDebugInfo('相机信息:');
        updateDebugInfo('  类型: ' + window.camera.constructor.name);
        updateDebugInfo('  位置: ' + window.camera.position.x.toFixed(2) + ', ' + window.camera.position.y.toFixed(2) + ', ' + window.camera.position.z.toFixed(2));
        updateDebugInfo('  FOV: ' + window.camera.fov);
        updateDebugInfo('  宽高比: ' + window.camera.aspect.toFixed(2));
    } else {
        updateDebugInfo('相机未初始化', true);
    }
    if (window.scene) {
        updateDebugInfo('场景信息:');
        updateDebugInfo('  对象数量: ' + window.scene.children.length);
        updateDebugInfo('  光源数量: ' + window.scene.children.filter(obj => obj.isLight).length);
        updateDebugInfo('  网格数量: ' + window.scene.children.filter(obj => obj.isMesh).length);
    } else {
        updateDebugInfo('场景未初始化', true);
    }
}

// 添加测试立方体
function addTestCube() {
    updateDebugInfo('添加线框测试立方体...');
    
    // 尝试从_sceneInstance获取对象
    if (!window.scene && window._sceneInstance) {
        window.scene = window._sceneInstance.scene;
    }
    if (!window.camera && window._sceneInstance) {
        window.camera = window._sceneInstance.camera;
    }
    if (!window.renderer && window._sceneInstance) {
        window.renderer = window._sceneInstance.renderer;
    }
    
    if (window.scene && window.camera && window.renderer) {
        const geometry = new THREE.BoxGeometry(2, 2, 2);
        const material = new THREE.MeshBasicMaterial({color: 0xffffff, wireframe: true});
        const cube = new THREE.Mesh(geometry, material);
        cube.name = "测试线框立方体";
        cube.position.set(0, 5, 0);
        window.scene.add(cube);
        const axesHelper = new THREE.AxesHelper(3);
        axesHelper.name = "测试坐标轴";
        axesHelper.position.copy(cube.position);
        window.scene.add(axesHelper);
        updateDebugInfo('测试对象已添加，X轴(红)，Y轴(绿)，Z轴(蓝)');
    } else {
        updateDebugInfo('无法添加测试对象：场景/相机/渲染器未初始化', true);
    }
}

// 绑定按钮事件
function bindDebugEvents() {
    document.getElementById('reload-btn').onclick = () => { updateDebugInfo('正在重新加载页面...'); setTimeout(() => location.reload(), 500); };
    document.getElementById('check-scene-btn').onclick = checkThreeEnv;
    document.getElementById('force-render-btn').onclick = forceRender;
    document.getElementById('show-info-btn').onclick = showInfo;
    document.getElementById('add-test-btn').onclick = addTestCube;
}

// 初始化调试工具
function initDebug() {
    createDebugPanel();
    updateDebugInfo('调试工具已初始化');
    
    // 尝试捕获场景对象
    patchScriptScene();
    captureSceneObjects();
    
    setTimeout(bindDebugEvents, 100); // 等待按钮渲染
}

// DOM加载后自动初始化
if (typeof window !== 'undefined') {
    window.addEventListener('DOMContentLoaded', initDebug);
}

// 导出接口
module.exports = { updateDebugInfo, checkThreeEnv }; 
# ==============================================================================
# Example environment config (NO SECRETS)
# Copy to `.env` and fill in real keys/urls/models for local running.
#
# NOTE:
# - `.env` is gitignored and should contain secrets.
# - `.env.example` is tracked to document required variables for deploy.
# ==============================================================================

# -------------------------------
# Enable stable V2 generation mode (recommended)
# -------------------------------
AI_V2_OUTPUT_MODE=wrapped_parts

# Total budget for /api/generate-effect-v2 (ms)
AI_V2_TOTAL_BUDGET_MS=90000

# -------------------------------
# AI provider config (PRIMARY / FALLBACK)
# -------------------------------
AI_PRIMARY_API_KEY=
AI_PRIMARY_BASE_URL=https://api.openai.com/v1
AI_PRIMARY_MODEL=gpt-4o

AI_FALLBACK_API_KEY=
AI_FALLBACK_BASE_URL=
AI_FALLBACK_MODEL=

# -------------------------------
# Server
# -------------------------------
PORT=3000

